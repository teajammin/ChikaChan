{
  "manifest_version": 3,
  "name": "ChikaChan for Crunchyroll",
  "version": "1.0",
  "description": "AI anime recommendations powered by ChikaChan, built for Crunchyroll",
  "permissions": [],
  "host_permissions": [
    "https://www.crunchyroll.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.crunchyroll.com/*"],
      "js": ["crunchyAI.js", "content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://www.crunchyroll.com/*"]
    }
  ]
}
