{
  "manifest_version": 3,
  "name": "ChikaChan – Anime Recommender",
  "version": "2.0.0",
  "description": "AI-powered anime recommendations on MyAnimeList and Crunchyroll, powered by Claude.",

  "permissions": [
    "activeTab"
  ],

  "host_permissions": [
    "https://myanimelist.net/*",
    "https://cdn.myanimelist.net/*",
    "https://www.crunchyroll.com/*",
    "https://chika-chan.vercel.app/*",
    "https://graphql.anilist.co/*",
    "https://s4.anilist.co/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://myanimelist.net/*",
        "https://www.crunchyroll.com/*"
      ],
      "js": ["chika.js", "crunchyAI.js", "content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_end"
    }
  ]
}
